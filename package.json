{
  "name": "homebridge-powershades",
  "version": "0.2.6",
  "displayName": "PowerShades",
  "description": "Homebridge plugin for PowerShades motorized window shades and blinds with cloud API and local RF Gateway V2 UDP control.",
  "main": "index.js",
  "bin": {
    "powershades-local-udp": "tools/powershades-local-udp.js"
  },
  "keywords": [
    "homebridge-plugin",
    "homebridge",
    "powershades",
    "window-covering",
    "window-shades",
    "motorized-shades",
    "blinds",
    "shades",
    "motorized",
    "smart-home",
    "local-control",
    "rf-gateway",
    "homekit",
    "window-blinds",
    "automated-shades",
    "roller-shades"
  ],
  "author": "Alex Schmelkin",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/apumapho/homebridge-powershades.git"
  },
  "bugs": {
    "url": "https://github.com/apumapho/homebridge-powershades/issues"
  },
  "homepage": "https://github.com/apumapho/homebridge-powershades#readme",
  "engines": {
    "node": ">=18.0.0",
    "homebridge": ">=1.6.0"
  },
  "license": "MIT",
  "scripts": {
    "local:udp": "node tools/powershades-local-udp.js",
    "test": "node --test __tests__/*.test.js",
    "test:watch": "node --test --watch __tests__/*.test.js"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/apumapho/homebridge-powershades"
  },
  "homebridge": {
    "displayName": "PowerShades",
    "pluginType": "platform",
    "config": "config.schema.json",
    "platforms": [
      {
        "platform": "PowerShades"
      }
    ]
  }
}
